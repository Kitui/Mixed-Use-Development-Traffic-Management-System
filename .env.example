DEBUG=False
SECRET_KEY=replace-this-with-a-long-random-secret
ALLOWED_HOSTS=127.0.0.1,localhost,your-demo-domain.example.com
CSRF_TRUSTED_ORIGINS=https://your-demo-domain.example.com

# Leave DATABASE_URL empty to use local SQLite for the prototype.
# For hosted PostgreSQL, use a URL like:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# Enable these only when your prototype host provides HTTPS.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
